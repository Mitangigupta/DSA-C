#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>
#include <string.h>
int precedence(char op){
    switch (op){
        case '+':
        case '-': return 1;
        case '*':
        case '/': return 2;
        case '^': return 3;
        default: return 0;
    }
}
char* convert(char* infix){
    int len = strlen(infix), top = -1, x = 0;
    char* post = (char*)malloc(len + 1);
    char operator[len];
    for (int i = 0; i < len; i++){
        char ch = infix[i];
        if (isalnum(ch)){
            post[x++] = ch;
        }
        else if (ch == '('){
            operator[++top] = ch;
        }
        else if (ch == ')'){
            while (top != -1 && operator[top] != '('){
                post[x++] = operator[top--];
            }
            top--; 
        }
        else { 
        while (top != -1 && precedence(ch) <= precedence(operator[top]) && ch != '^'){ 
            post[x++] = operator[top--]; 
        }
            operator[++top] = ch;
        }
    }
    while (top != -1){
        post[x++] = operator[top--];
    }
    post[x] = '\0';
    return post;
}
int main (){
    char exp[100];
    fgets(exp, sizeof(exp), stdin);
    exp[strcspn(exp, "\n")] = '\0';
    printf("%s", convert(exp));
    return 0;
}
