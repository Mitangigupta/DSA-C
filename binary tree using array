//binary tree using array
#include<stdio.h>
#include<stdlib.h>
#define max 100
int tree[max], idx=0;
void initTree(){
    for(int i=0; i<max; i++){
        tree[i] = -1;
    }
}
void insert(int val){
    if(idx<max){
        tree[idx++] = val;
    }
    else
        printf("TREE IS FULL\n");
}
void levelorder(){
    for(int i=0; i<idx; i++){
        if(tree[i] != -1)
            printf("%d ",tree[i]);
    }
}
void preorder(int index){
    if(index>=max || tree[index] == -1)
        return;
    printf("%d ", tree[index]);
    preorder(2*index+1);
    preorder(2*index+2);
}
void inorder(int index){
    if(index>=max || tree[index] == -1)
        return;
    printf("%d ", tree[index]);
    preorder(2*index+1);
    preorder(2*index+2);
}
void postorder(int index){
    if(index>=max || tree[index] == -1)
        return;
    printf("%d ", tree[index]);
    preorder(2*index+1);
    preorder(2*index+2);
}
int search(int val){
    for(int i=0;i<idx;i++){
        if(val==tree[i])
        return i;
    }
    return -1;
}
void delete(int val){
   int index = search(val);
   if(index==-1)
   printf("ELEMENT NOT FOUND IN TREE!!!\n");
   else{
    tree[index] = tree[--idx];
    printf("Node deleted!!!!\n");
   }
}
int main(){
    int choice, val;
    initTree();
    while (1){
        printf("\n ***** Binary Tree Menu *****\n");
        printf("1. Insert\n");
        printf("2. Level Order Traversal\n");
        printf("3. Pre-Order Traversal\n");
        printf("4. In-Order Traversal\n");
        printf("5. Post-Order Traversal\n");
        printf("6. Search\n");
        printf("7. Delete\n");
        printf("8. Exit\n ");
        printf("Enter Choice: ");
        scanf("%d", &choice);
        switch(choice){
            case 1:
            printf("enter value: ");
            scanf("%d",&val);
            insert(val);
                break;
            case 2:
            levelorder();
                break;
            case 3:
            preorder(0);
                break;
            case 4:
            inorder(0);
                break;
            case 5:
            postorder(0);
                break;
            case 6:
            printf("enter searching element");
            scanf("%d",&val);
            if(search(val)==-1)
                printf("Not found !!!\n");
            else
                printf("Found!!!!\n");
                break;
            case 7:
            printf("enter deleting element: ");
            scanf("%d",&val);
            delete(val);
            break;
            case 8:
                exit(0);
            default:
                printf("Invalid choice !!!!\n");
        }
    }
    return 0;
    
}
