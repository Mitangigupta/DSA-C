         printf("Delete from begining\n");
    }
} 
void DeleteFromEnd(){
    if(head == NULL)
       printf("List is empty!!!\n");
    else if(head->next == NULL){
        head = tail = NULL;
          printf("Deleted from end\n");
    }
    else{
        struct Node* temp = head;
        while(temp->next!=NULL){
            temp = temp->next;
        }
        temp->prev->next = NULL;
        tail = tail->prev;
        printf("Deleted from end\n");
    }
} 
