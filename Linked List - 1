#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
struct node{
    int data;
    struct node* next;
};
struct node* head = NULL;
struct node* createnode(int data){
    struct node* temp = (struct node*)malloc(sizeof(struct node));
    temp->data = data;
    temp->next=NULL;
    return temp;
}
void insertatbeg(int data){
    struct node* newnode=createnode(data);
    newnode->next=head;
    head=newnode;
}
void deletefrompos(int pos){
    if(head == NULL) return;

    if(pos == 1){
        head = head->next;
        return;
    }

    struct node* temp = head;
    int i = 0;

    while(temp != NULL && i < pos-2){
        temp = temp->next;
        i++;
    }

    if(temp == NULL || temp->next == NULL)
        return;

    temp->next = temp->next->next;
}

void insertatend(int data){
    struct node* newnode=createnode(data);
    if(head==NULL)
        head = newnode;
     else{
         struct node* temp = head;
         while(temp->next!=NULL){
             temp = temp->next;
         }
         temp->next=newnode;
     }
}
void insertatpos(int data,int pos){
    if(head==NULL)
      return;
    else if(pos==1)
       insertatbeg(data);
    else{
        struct node* temp = head;
        int i=0;
        while(temp!=NULL){
            if(i==pos-2)
            break;
        temp = temp->next;
        i++;
        }
        if(temp==NULL|| temp -> next == NULL)
            return;
        else{
            struct node* newnode = createnode(data);
            newnode->next = temp->next;
            temp->next = newnode;
        }
    }        
}
void display(){
    struct node* temp = head;
    while (temp != NULL) {
        printf("%d ", temp->data);
        temp = temp->next;
    }
}
int main() { 
     int N, x;
    scanf("%d", &N);
    for (int i = 0; i < N; i++) {
        scanf("%d", &x);
        insertatend(x);
    }
    int beg;
    scanf("%d", &beg);
    insertatbeg(beg);
    int Pos;
    scanf("%d", &Pos);
    deletefrompos(Pos);
    int Val;
    scanf("%d",&Val);
    insertatend(Val);
    int pos, val;
    scanf("%d %d", &pos, &val);
    insertatpos(val, pos);
    display();
    return 0;
}
